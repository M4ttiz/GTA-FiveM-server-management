# .editorconfig

# EditorConfig is awesome: https://EditorConfig.org

# Top-most EditorConfig file
root = true

# Unix-style newlines with a newline ending every file
[*]
end_of_line = lf
insert_final_newline = true
charset = utf-8
trim_trailing_whitespace = true

# PHP Files
[*.php]
indent_style = space
indent_size = 4

# JavaScript Files
[*.{js,jsx,ts,tsx}]
indent_style = space
indent_size = 2

# CSS/SCSS Files
[*.{css,scss}]
indent_style = space
indent_size = 2

# HTML Files
[*.{html,htm}]
indent_style = space
indent_size = 2

# JSON Files
[*.json]
indent_style = space
indent_size = 2

# YAML Files
[*.{yaml,yml}]
indent_style = space
indent_size = 2

# Markdown Files
[*.md]
trim_trailing_whitespace = false
